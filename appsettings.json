{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
    }
  },
  "Cors": {
    "Urls": [
      "*"
    ]
  },
  "OpenSearch": {
    "Url": "https://localhost:9200",
    "User": "admin",
    "Password": "admin"
  },
  "Storages": {
    "Sms": "sms_logs", //sms.stage.log
    "Call": "call_logs" //call.stage.log
  },
  "SmsRu": {
    "Url": "https://sms.ru",
    "From": "number",
    "ApiId": "api_key"
  },
  "SmsRu2": {
    "Url": "https://sms.ru",
    "From": "nubmer",
    "ApiId": "api_key"
  },
  "QueueSettings": {
    "SmsMaxSize": 1000, //размер очереди смс
    "SmsBatchSize": 10, // количество смс, которое обрабатываем из очереди за раз
    "SmsQueueIntervalMs": 60000, // интервал запуска обработчика очереди SMS (в миллисекундах, например, каждые 60 секунд)
    "SmsBatchIntervalMs": 1000, // задержка между обработкой отдельных пакетов SMS (в миллисекундах, например, 1 секунда)

    "SmsCallbackMaxSize": 1000, //размер очереди callback смс
    "SmsCallbackBatchSize": 10, // количество callback смс, которое обрабатываем из очереди за раз
    "SmsCallbackQueueIntervalMs": 60000, // интервал запуска обработчика очереди callback SMS (в миллисекундах, например, каждые 60 секунд)
    "SmsCallbackBatchIntervalMs": 1000, // задержка между обработкой отдельных пакетов callback SMS (в миллисекундах, например, 1 секунда)
    "MaxSmsAttempts": 5, // количество попыток отправить callback перед уалением из очереди

    "CallMaxSize": 500, // размер очереди звонков
    "CallBatchSize": 10, // количество звонков, которое обрабатываем из очереди за раз
    "CallQueueIntervalMs": 60000, // интервал запуска обработчика очереди звонков (в миллисекундах, например, каждые 60 секунд)
    "CallBatchIntervalMs": 1000, // задержка между обработкой отдельных пакетов звонков (в миллисекундах, например, 1 секунда),

    "CallCallbackMaxSize": 500, // размер очереди callback звонков
    "CallCallbackBatchSize": 10, // количество callback звонков, которое обрабатываем из очереди за раз
    "CallCallbackQueueIntervalMs": 60000, // интервал запуска обработчика очереди callback звонков (в миллисекундах, например, каждые 60 секунд)
    "CallCallbackBatchIntervalMs": 1000, // задержка между обработкой отдельных пакетов callback звокнов (в миллисекундах, например, 1 секунда),
    "MaxCallAttempts": 5 // количество попыток отправить callback перед уалением из очереди
  },
  "Authorization": {
    "Token": "your-token"
  },
  "AllowedHosts": "*",
  "MonitoringHosts": [
    "localhost"
  ]
}