{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
    }
  },
  "Cors": {
    "Urls": [
      "*"
    ]
  },
  "OpenSearch": {
    "Url": "https://localhost:9200",
    "User": "admin",
    "Password": "admin"
  },
  "Storages": {
    "Sms": "sms_logs",
    "Call": "call_logs"
  },
  "SmsRu": {
    "Url": "https://sms.ru",
    "From": "number",
    "ApiId": "api_key"
  },
  "SmsRu2": {
    "Url": "https://sms.ru",
    "From": "nubmer",
    "ApiId": "api_key"
  },
  "QueueSettings": {
    "SmsMaxSize": 1000,
    "CallMaxSize": 500
  },
  "Authorization": {
    "Token": "your-token"
  },
  "AllowedHosts": "*"
}